# Cloud Computing Program: Upload file to AWS S3

import boto3

# Create S3 client
s3 = boto3.client('s3')

# File details
file_name = 'test.txt'        # file in your system
bucket_name = 'your-bucket-name'   # your S3 bucket
object_name = 'test.txt'

# Upload file
try:
    s3.upload_file(file_name, bucket_name, object_name)
    print("File uploaded successfully to cloud!")
except Exception as e:
    print("Error:", e)
